// Firestore rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function userRole() {
      return (isSignedIn() &&
              exists(/databases/$(database)/documents/users/$(request.auth.uid)))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isEditor() {
      return isSignedIn() && (
        userRole() == "editor" ||
        request.auth.token.email == "wallentinetyler@gmail.com"
      );
    }

    // ========== Projects ==========
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isEditor();

      // Phases subcollection (used by the project editor & Read More modal)
      match /phases/{phaseId} {
        allow read: if true;
        allow create, update, delete: if isEditor();
      }
    }

    // ========== Users ==========
    // A user may read + edit their OWN profile, but NOT the privileged fields
    // (role / approved / disabled) — those are editor-only, so users can't
    // self-promote or self-approve. Editors may read/write everyone.
    match /users/{uid} {
      allow read: if isSelf(uid) || isEditor();
      allow create: if isSelf(uid);
      allow update: if isEditor() ||
        (isSelf(uid) &&
         !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'approved', 'disabled']));
      allow delete: if isEditor();
    }

    // ========== Posts ==========
    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // ========== Pages (e.g. pages/about-me) ==========
    // Publicly readable so About Me loads for everyone; editors write.
    // (Merged the two previous duplicate /pages blocks into this one.)
    match /pages/{pageId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // ========== Email Subscribers (managed by the admin console) ==========
    match /subscribers/{docId} {
      allow create: if true;                 // future public newsletter signup
      allow read, update, delete: if isEditor();
    }

    // ========== Survey responses ==========
    match /survey_responses/{responseId} {
      allow create: if true;
      allow read: if true;  // <-- enable read temporarily
      allow update, delete: if false;
    }
  }
}
