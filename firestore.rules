// Firestore rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function userRole() {
      return (isSignedIn() &&
              exists(/databases/$(database)/documents/users/$(request.auth.uid)))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isEditor() {
      return isSignedIn() && (
        userRole() == "editor" ||
        request.auth.token.email == "wallentinetyler@gmail.com"
      );
    }

    // ========== Projects ==========
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isEditor();

      // Phases subcollection (used by the project editor & Read More modal)
      match /phases/{phaseId} {
        allow read: if true;
        allow create, update, delete: if isEditor();
      }
    }

    // ========== Users ==========
    // A user may read + edit their OWN profile, but NOT the privileged fields
    // (role / approved / disabled) — those are editor-only, so users can't
    // self-promote or self-approve. Editors may read/write everyone.
    match /users/{uid} {
      allow read: if isSelf(uid) || isEditor();
      allow create: if isSelf(uid);
      allow update: if isEditor() ||
        (isSelf(uid) &&
         !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'approved', 'disabled']));
      allow delete: if isEditor();
    }

    // ========== Posts ==========
    match /posts/{postId} {
      allow read: if true;
      allow create, delete: if isEditor();
      // Editors may edit anything. Anyone else may update ONLY the `views`
      // counter (so opening a post can bump its view count).
      allow update: if isEditor() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']);
    }

    // ========== Pages (e.g. pages/about-me) ==========
    // Publicly readable so About Me loads for everyone; editors write.
    // (Merged the two previous duplicate /pages blocks into this one.)
    match /pages/{pageId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // ========== Email Subscribers ==========
    // Subscriber docs are keyed by (lowercased) email. Schema:
    //   email (string), linkedaccount ("N/A" or the user's uid),
    //   status ("pending"|"active"|"inactive"), active (bool, kept in sync)
    // Creation + all Zoho-synced writes go through the `subscribe` /
    // `unsubscribe` Cloud Functions (admin SDK, which bypasses these rules), so
    // clients can't create subscriptions directly. A signed-in user still
    // "owns" the subscription whose email matches their auth token, so the
    // profile page can READ its status and link it to their account. Editors
    // manage everything from the admin console.
    match /subscribers/{docId} {
      function ownsSubByEmail() {
        return isSignedIn() &&
               request.auth.token.email != null &&
               resource.data.email == request.auth.token.email;
      }
      allow create: if isEditor();
      allow read:   if isEditor() || ownsSubByEmail();
      allow update: if isEditor() || ownsSubByEmail();
      allow delete: if isEditor();
    }

    // ========== Survey responses ==========
    match /survey_responses/{responseId} {
      allow create: if true;
      allow read: if true;  // <-- enable read temporarily
      allow update, delete: if false;
    }
  }
}
