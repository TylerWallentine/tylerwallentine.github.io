rules_version = '2';

// ============================================================
// Firebase Storage Security Rules — Vapor Rain Website
// ------------------------------------------------------------
// Reference copy kept in the repo. The LIVE rules live in the
// Firebase console (Storage -> Rules) — you MUST publish there for
// changes to take effect. Deploy via CLI: firebase deploy --only storage
//
// Layout (folder / owner-id / rest-of-path):
//   images/{postId}/<file>                    blog post images
//   attachments/{postId}/<file>               blog post attachments
//   projectImages/{projectId}/<file>          project images
//   attachments/{projectId}/{phaseId}/<file>  per-phase project attachments
//   previewImages/{ownerId}/<file>            post/project preview images
//
// Public read for everything. Write is allowed if the signed-in user is
// the owner (uid matches the {userId} segment), is the site owner (by AUTH
// TOKEN email — reliable, no Firestore read), or has the Firestore role
// "Editor". The token-email check is listed early so it short-circuits and
// never needs the cross-service Firestore lookup for the owner account.
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    // Match any first-level folder (images, attachments, projectImages, ...).
    match /{folder}/{userId}/{allPaths=**} {

      // Public read access for all uploaded content.
      allow read: if true;

      allow write: if request.auth != null && (
        // 1) The uploader owns this folder (their uid is the {userId} segment).
        request.auth.uid == userId ||

        // 2) Site owner, verified via the auth token email (no Firestore read).
        request.auth.token.email == "wallentinetyler@gmail.com" ||

        // 3) A user whose Firestore profile has role "Editor".
        //    NOTE: in Storage rules, cross-service Firestore access uses the
        //    `firestore.` prefix (not a bare get()). Guarded with exists() so a
        //    missing user doc can't error the rule.
        (
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "Editor"
        )
      );
    }
  }
}
