rules_version = '2';

// ============================================================
// Firebase Storage Security Rules — Vapor Rain Website
// ------------------------------------------------------------
// Reference copy kept in the repo. The LIVE rules live in the
// Firebase console (Storage -> Rules). Deploy with the CLI via:
//     firebase deploy --only storage
//
// Layout used by the site (folder / owner-id / rest-of-path):
//   images/{postId}/<file>                    blog post images
//   attachments/{postId}/<file>               blog post attachments
//   projectImages/{projectId}/<file>          project images
//   attachments/{projectId}/{phaseId}/<file>  per-phase project attachments
//
// The second path segment is treated as the "owner" id. Public read
// is allowed for everything; writes require an authenticated user who
// is the owner, has the Firestore role "Editor", or is the site owner.
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    // Match any first-level folder (images, attachments, projectImages, etc.)
    match /{folder}/{userId}/{allPaths=**} {

      // Public read access for all uploaded content.
      allow read: if true;

      // Write rules:
      // - Authenticated user, AND
      // - Either the owner (userId segment matches their uid)
      // - OR their Firestore role is "Editor"
      // - OR their email is the site owner's.
      allow write: if request.auth != null &&
        (
          request.auth.uid == userId ||
          get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "Editor" ||
          get(/databases/(default)/documents/users/$(request.auth.uid)).data.email == "wallentinetyler@gmail.com"
        );
    }
  }
}
